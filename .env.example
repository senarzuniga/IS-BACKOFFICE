# IS-BACKOFFICE — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# The .env file is git-ignored; never commit secrets.

# ---------------------------------------------------------------------------
# Supabase (Required for database persistence and Ingecart data)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_ANON_KEY=<your-anon-key>

# Policy:
# - Backend (server) must use SUPABASE_SERVICE_ROLE_KEY for privileged operations.
# - SUPABASE_ANON_KEY is only for frontend or backend flows that must respect RLS.
# - Do not use generic variables like SUPABASE_KEY.

# ---------------------------------------------------------------------------
# OpenAI (Optional — enables AI enhancement in document analysis)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Application Settings (Optional)
# ---------------------------------------------------------------------------
IS_BACKOFFICE_API_URL=http://localhost:8000
