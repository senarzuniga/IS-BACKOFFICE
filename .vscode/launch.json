{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Streamlit app",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/streamlit_app.py"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run unit tests (unittest)",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": [
        "discover",
        "-s",
        "tests",
        "-q"
      ],
      "justMyCode": true
    }
  ]
}
